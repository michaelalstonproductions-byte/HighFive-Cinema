# HighFive Cinema LP1 production infrastructure example.
# Copy to .env.production and set values on the deployment host.
# Do not commit .env.production or secret files.

HIGHFIVE_BACKEND_ENV=production
HIGHFIVE_DEPLOYMENT_STATUS=production_infrastructure_ready
HIGHFIVE_PROVIDER_MODE=mock
HIGHFIVE_SERVER_HOST=0.0.0.0
HIGHFIVE_SERVER_PORT=8787
HIGHFIVE_RATE_LIMIT_REQUESTS=1200
HIGHFIVE_RATE_LIMIT_WINDOW_MS=60000

HIGHFIVE_API_PORT=8787
HIGHFIVE_CDN_PORT=8080
HIGHFIVE_DASHBOARD_PORT=8790
HIGHFIVE_PROMETHEUS_PORT=9090
HIGHFIVE_LOG_PORT=24224

HIGHFIVE_POSTGRES_DB=highfive_cinema
HIGHFIVE_POSTGRES_USER=highfive_app
HIGHFIVE_POSTGRES_PASSWORD_FILE=/run/secrets/highfive_postgres_password
HIGHFIVE_DATABASE_URL_FILE=/run/secrets/highfive_database_url

HIGHFIVE_OBJECT_STORAGE_ENDPOINT=object-storage:9000
HIGHFIVE_OBJECT_STORAGE_BUCKET=highfive-media
HIGHFIVE_OBJECT_STORAGE_ACCESS_KEY_FILE=/run/secrets/highfive_object_storage_access_key
HIGHFIVE_OBJECT_STORAGE_SECRET_KEY_FILE=/run/secrets/highfive_object_storage_secret_key

HIGHFIVE_MEDIA_QUEUE_NAME=highfive-media-processing
HIGHFIVE_OBJECT_STORAGE_MODE=s3_compatible
HIGHFIVE_AUDIT_LOG_SINK=stdout

