    "user_id": {
      "type": [
        "string",
        "null"
      ]
    },
    "anonymous_session_id": {
      "type": [
        "string",
        "null"
      ]
    },
    "movie_id": {
      "type": "string",
      "minLength": 1
    },
    "storekit_product_id": {
      "type": "string",
      "minLength": 1
    },
    "entitlement_context": {
      "type": "object"
    },
    "playback_provider": {
      "type": "string",
      "minLength": 1
    },
    "device_context": {
      "type": "object"
    }
