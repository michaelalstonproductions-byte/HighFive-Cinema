{
  "$id": "highfive.entitlements.validate.request.schema.json",
  "title": "HighFive Entitlement Validation Request",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "user_id",
    "anonymous_session_id",
    "movie_id",
    "storekit_product_id",
    "entitlement_context",
    "playback_provider",
    "device_context"
  ],
